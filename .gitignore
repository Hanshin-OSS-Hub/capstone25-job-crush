# 의존성 패키지 폴더
**/node_modules

# 빌드 결과물
**/dist
**/build

# 로그 파일
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 운영체제 생성 파일
.DS_Store
Thumbs.db

# 에디터 및 IDE 설정 폴더
.idea
.vscode/

# 환경 변수 파일 (민감 정보 포함 가능)
# 모든 .env* 파일을 무시하되, .env.example 파일은 예외로 함
.env*
!*.env.example
!**/.env.example
