# Application
PORT=3000

# CORS (쉼표로 여러 출처. 프론트 포트 바꾸면 여기도 동일하게)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Database (PostgreSQL 예시)
DATABASE_URL=postgresql://user:password@db:5432/mydatabase

# Google Gemini — Model code는 https://ai.google.dev/gemini-api/docs/models/gemini 과 일치해야 함
# 예: gemini-3.1-flash-lite-preview | gemini-3-flash-preview | gemini-3.1-pro-preview
GOOGLE_API_KEY=your_google_ai_studio_api_key
# 미설정 시 gemini-3.1-flash-lite-preview (gemini-3.1-flash 는 유효한 ID 아님 → 404)
# GEMINI_MODEL=gemini-3.1-pro-preview

# ML 마이크로서비스 (Python/FastAPI) — STT 및 영상 멀티모달 분석
# Docker Compose 사용 시 http://ml-service:8000, 로컬 직접 실행 시 http://localhost:8000
ML_SERVICE_URL=http://localhost:8000

# 외부 API (예시)
SOME_API_KEY=your_api_key_here
